{
  "manifest_version": 3,
  "name": "Side Collector",
  "version": "2.1.0",
  "description": "네이버 카페, 쿠팡, 아이허브, LinkedIn, Threads, X, YouTube에서 데이터 수집",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting", "webNavigation", "downloads", "sidePanel", "storage"],
  "host_permissions": [
    "https://cafe.naver.com/*",
    "https://www.coupang.com/*",
    "https://*.iherb.com/*",
    "https://www.youtube.com/*",
    "https://www.linkedin.com/*",
    "https://www.threads.net/*",
    "https://www.threads.com/*",
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "action": {
    "default_icon": {
      "48": "icon48.png"
    }
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://cafe.naver.com/*"],
      "js": ["scrapers/naver-cafe.js"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.coupang.com/vp/products/*"],
      "js": ["scrapers/coupang.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.iherb.com/r/*", "https://*.iherb.com/pr/*"],
      "js": ["scrapers/iherb.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["scrapers/youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["scrapers/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.threads.net/*", "https://www.threads.com/*"],
      "js": ["scrapers/threads.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["scrapers/x-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["scrapers/x-injected.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ]
}
